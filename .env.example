# -------------------------------------------------
# Yesterday's Scoop - installer-managed environment
# -------------------------------------------------
# These values are created by scripts/install.sh and remain host/env-managed.

# Host ports
YS_WEB_PORT=8000
YS_MINIFLUX_PORT=8080
YS_MEILI_PORT=7700
YS_OLLAMA_PORT=11434

# Host persistence root (bind mounts)
YS_DATA_ROOT=./data

# App image name (local build tag by default)
YS_APP_IMAGE=yesterdays-scoop:local

# Required: app auth and initial admin
AUTH_SECRET=replace-with-a-long-random-secret
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=change-me

# App DB
APP_DB_NAME=scoop
APP_DB_USER=scoop
APP_DB_PASSWORD=change-me
DATABASE_URL=postgresql+psycopg://scoop:change-me@app_db:5432/scoop

# Miniflux DB
MINIFLUX_DB_NAME=miniflux
MINIFLUX_DB_USER=miniflux
MINIFLUX_DB_PASSWORD=change-me
MINIFLUX_DATABASE_URL=postgres://miniflux:change-me@miniflux_db:5432/miniflux?sslmode=disable

# Miniflux bootstrap admin
MINIFLUX_ADMIN_USERNAME=admin
MINIFLUX_ADMIN_PASSWORD=change-me

# Meilisearch admin key
MEILI_MASTER_KEY=replace-with-a-long-random-key

# Service wiring (normally unchanged)
REDIS_URL=redis://redis:6379/0
MINIFLUX_BASE_URL=http://miniflux:8080
MEILI_URL=http://meilisearch:7700
POLL_INTERVAL_MINUTES=15
ENABLE_AI_SUMMARIZATION=true

# AI provider defaults (GUI can override DB-backed behavior)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_CHAT_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Optional defaults
DEFAULT_REGION=Global
DEFAULT_TOPICS=world,politics,business,technology,science

# Social context connector defaults
ENABLE_SOCIAL_CONTEXT=false
ENABLE_REDDIT_CONTEXT=true
ENABLE_X_CONTEXT=false
SOCIAL_MAX_ITEMS=8
X_API_BEARER_TOKEN=
